{
  "$schema": "https://opencode.ai/config.json",
  "formatter": {
    "uv": {
      "disabled": true
    },
    "ruff": {
      "disabled": true
    },
    "yapf": {
      "command": [
        "yapf",
        "$FILE"
      ],
      "extensions": [
        ".py"
      ]
    },
  },
  "mcp": {
    "atlassian": {
      "url": "https://mcp.atlassian.com/v1/sse",
      "type": "remote",
      "enabled": false
    },
    "github/github-mcp-server": {
      "url": "https://api.githubcopilot.com/mcp/",
      "type": "remote",
      "enabled": false
    }
  },
  "instructions": [
    "**/.github/copilot-instructions.md",
    "**/.github/instructions/*.instructions.md",
  ],
  
}